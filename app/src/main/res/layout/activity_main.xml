<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✈ Travel Companion"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"/>

        <!-- CATEGORY SELECTOR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Conversion Category:"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp"/>

        <!-- FROM UNIT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Convert From:"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerSourceUnit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp"/>

        <!-- TO UNIT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Convert To:"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerDestinationUnit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp"/>

        <!-- INPUT VALUE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter Value:"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editTextInputValue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. 100"
            android:inputType="numberDecimal|numberSigned"
            android:background="@drawable/edittext_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <!-- CONVERT BUTTON -->
        <Button
            android:id="@+id/buttonConvert"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CONVERT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- RESULT DISPLAY -->
        <TextView
            android:id="@+id/textViewResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result will appear here"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:gravity="center"
            android:background="@drawable/result_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>